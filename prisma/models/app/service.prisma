model Service {
  code               String   @id
  name               String   @db.VarChar(250)
  description        String   @db.VarChar(1000)
  publicName         String   @db.VarChar(500) @map("public_name")
  ticketPrefix       String   @db.VarChar(10) @map("ticket_prefix")
  legacyServiceId    Int?     @map("legacy_service_id")
  backOffice         Boolean  @map("back_office") @default(false)

  locations          Location[]

  deletedAt          DateTime? @db.Timestamp(6) @map("deleted_at")
  createdAt          DateTime @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt          DateTime @updatedAt @db.Timestamp(6) @map("updated_at")

  @@map("service")
  @@schema("app")
}
